ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
OPENAI_API_KEY=
# Model strings — override to swap a provider model without code changes
CLAUDE_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4o
SYNTHESIZER_MODEL=claude-opus-4-6
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# development | production — controls log format (console vs JSON) and HSTS header
ENVIRONMENT=development

# Comma-separated CORS allowlist. Localhost entries are recommended only in development.
# In production, set this to the public domains of the frontends that call this API.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
