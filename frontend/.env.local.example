# Backend API URL — no trailing slash. Defaults to http://localhost:8000 if absent.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Required for cross-subdomain SSO. Set to the auth backend URL
# (e.g. https://dome-process-analyzer-production.up.railway.app).
# If absent, auth context will silently fail to initialise.
NEXT_PUBLIC_AUTH_BACKEND=

# Optional — canonical URL for this deployment (used for absolute URL generation).
NEXT_PUBLIC_SITE_URL=
